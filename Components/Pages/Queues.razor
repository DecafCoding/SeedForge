@page "/queues"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Options
@using SeedForge.Data
@using SeedForge.Domain
@using SeedForge.Features.Maintenance
@using SeedForge.Services.Queues
@using SeedForge.Workers
@inject ApplicationDbContext Db
@inject VideoQueue VideoQueue
@inject ConceptQueue ConceptQueue
@inject WorkerControl Control
@inject IOptions<WorkerOptions> WorkerOptions
@inject BackfillVideoMetadataHandler BackfillMetadata

<PageTitle>Queues</PageTitle>

<h1>Queues</h1>
<p>Per-worker monitoring and controls for the unattended pipeline: pending counts, drain-time ETA, pause/resume, process-now, and recent item states. Workers start <strong>paused</strong> on boot — resume them here when you're ready to spend on Apify / the model.</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
@if (_message is not null)
{
    <div class="alert alert-success">@_message</div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Processing (videos)</h5>
                <p class="card-text">
                    Pending: <strong>@_pendingVideos</strong><br />
                    Drain ETA: <strong>@QueueEta.Format(_pendingVideos, _opts.ProcessingIntervalSeconds)</strong>
                    <small class="text-muted">(@_opts.ProcessingIntervalSeconds s / item)</small><br />
                    Status: <strong class="@StatusClass(Worker.Processing)">@StatusText(Worker.Processing)</strong>
                </p>
                <button class="btn btn-sm btn-primary me-2" disabled="@_busy" @onclick="() => Toggle(Worker.Processing)">
                    @(Control.IsPaused(Worker.Processing) ? "Resume" : "Pause")
                </button>
                <div class="input-group input-group-sm mt-2">
                    <input class="form-control" type="number" placeholder="video id" @bind="_processVideoId" disabled="@_busy" />
                    <button class="btn btn-outline-secondary" disabled="@(_busy || _processVideoId is null)" @onclick="ProcessVideoNow">Process now</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Concept (jobs)</h5>
                <p class="card-text">
                    Pending: <strong>@_pendingConcepts</strong><br />
                    Drain ETA: <strong>@QueueEta.Format(_pendingConcepts, _opts.ConceptIntervalSeconds)</strong>
                    <small class="text-muted">(@_opts.ConceptIntervalSeconds s / item)</small><br />
                    Status: <strong class="@StatusClass(Worker.Concept)">@StatusText(Worker.Concept)</strong>
                </p>
                <button class="btn btn-sm btn-primary me-2" disabled="@_busy" @onclick="() => Toggle(Worker.Concept)">
                    @(Control.IsPaused(Worker.Concept) ? "Resume" : "Pause")
                </button>
                <div class="input-group input-group-sm mt-2">
                    <input class="form-control" type="number" placeholder="job id" @bind="_processJobId" disabled="@_busy" />
                    <button class="btn btn-outline-secondary" disabled="@(_busy || _processJobId is null)" @onclick="ProcessConceptNow">Process now</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Discovery (channels)</h5>
                <p class="card-text">
                    Channels followed: <strong>@_channels</strong><br />
                    Poll interval: <strong>@FormatInterval(_opts.DiscoveryIntervalSeconds)</strong><br />
                    Status: <strong class="@StatusClass(Worker.Discovery)">@StatusText(Worker.Discovery)</strong>
                </p>
                <button class="btn btn-sm btn-primary me-2" disabled="@_busy" @onclick="() => Toggle(Worker.Discovery)">
                    @(Control.IsPaused(Worker.Discovery) ? "Resume" : "Pause")
                </button>
                <a class="btn btn-sm btn-outline-secondary" href="channels">Manage channels</a>
            </div>
        </div>
    </div>
</div>

<hr />

<h2>Add a YouTube URL to the processing queue</h2>
<div class="input-group mb-3" style="max-width:40rem">
    <input class="form-control" placeholder="https://www.youtube.com/watch?v=…" @bind="_urlInput" disabled="@_busy" />
    <button class="btn btn-primary" disabled="@(_busy || string.IsNullOrWhiteSpace(_urlInput))" @onclick="EnqueueUrl">
        @(_busy ? "Working…" : "Add to queue")
    </button>
</div>

<hr />

<h2>Maintenance</h2>
<p>Backfill video metadata (duration, views, likes, publish date, …) for videos ingested before metadata capture, by re-parsing the Apify item already stored with each transcript. <strong>Free</strong> — no Apify re-fetch. Idempotent: safe to run repeatedly.</p>
<button class="btn btn-outline-secondary mb-3" disabled="@_busy" @onclick="BackfillMetadataAsync">
    @(_busy ? "Working…" : "Backfill video metadata")
</button>

<hr />

<button class="btn btn-link" disabled="@_busy" @onclick="RefreshAsync">Refresh</button>

<div class="row mt-3">
    <div class="col-md-6">
        <h2>Recent videos</h2>
        @if (_recentVideos.Count == 0)
        {
            <p><em>No videos enqueued yet.</em></p>
        }
        else
        {
            <table class="table table-sm">
                <thead><tr><th>#</th><th>Title / id</th><th>State</th><th>Attempts</th></tr></thead>
                <tbody>
                    @foreach (var v in _recentVideos)
                    {
                        <tr>
                            <td>@v.Id</td>
                            <td>@(string.IsNullOrWhiteSpace(v.Title) ? v.YouTubeVideoId : v.Title)</td>
                            <td>@VideoStateLabel(v.Status)</td>
                            <td>@v.AttemptCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    <div class="col-md-6">
        <h2>Recent concept jobs</h2>
        @if (_recentJobs.Count == 0)
        {
            <p><em>No concept jobs yet.</em></p>
        }
        else
        {
            <table class="table table-sm">
                <thead><tr><th>#</th><th>Idea</th><th>State</th><th>Attempts</th></tr></thead>
                <tbody>
                    @foreach (var j in _recentJobs)
                    {
                        <tr>
                            <td>@j.Id</td>
                            <td>#@j.IdeaId</td>
                            <td>@ConceptStateLabel(j.Status)</td>
                            <td>@j.AttemptCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private WorkerOptions _opts = new();
    private int _pendingVideos;
    private int _pendingConcepts;
    private int _channels;
    private string _urlInput = string.Empty;
    private int? _processVideoId;
    private int? _processJobId;
    private List<Video> _recentVideos = new();
    private List<ConceptJob> _recentJobs = new();
    private bool _busy;
    private string? _error;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        _opts = WorkerOptions.Value;
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _error = null;
        try
        {
            _pendingVideos = await VideoQueue.CountPendingAsync();
            _pendingConcepts = await ConceptQueue.CountPendingAsync();
            _channels = await Db.Channels.CountAsync();
            _recentVideos = await Db.Videos.OrderByDescending(v => v.Id).Take(15).ToListAsync();
            _recentJobs = await Db.ConceptJobs.OrderByDescending(j => j.Id).Take(15).ToListAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load queue state: {ex.Message}";
        }
    }

    private void Toggle(Worker worker)
    {
        if (Control.IsPaused(worker)) Control.Resume(worker);
        else Control.Pause(worker);
    }

    private async Task EnqueueUrl()
    {
        await RunAsync(async () =>
        {
            var id = await VideoQueue.EnqueueAsync(_urlInput);
            _message = $"Enqueued video #{id}.";
            _urlInput = string.Empty;
        });
    }

    private async Task ProcessVideoNow()
    {
        await RunAsync(async () =>
        {
            await VideoQueue.ProcessNowAsync(_processVideoId!.Value);
            _message = $"Video #{_processVideoId} prioritized; Processing worker woken.";
        });
    }

    private async Task ProcessConceptNow()
    {
        await RunAsync(async () =>
        {
            await ConceptQueue.ProcessNowAsync(_processJobId!.Value);
            _message = $"Job #{_processJobId} prioritized; Concept worker woken.";
        });
    }

    private async Task BackfillMetadataAsync()
    {
        await RunAsync(async () =>
        {
            var result = await BackfillMetadata.HandleAsync();
            _message = $"Backfill complete: {result.Updated} of {result.Scanned} candidate video(s) updated.";
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _busy = true;
        _error = null;
        _message = null;
        try
        {
            await action();
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private string StatusText(Worker w) => Control.IsPaused(w) ? "Paused" : "Running";
    private string StatusClass(Worker w) => Control.IsPaused(w) ? "text-warning" : "text-success";

    private static string FormatInterval(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalDays >= 1) return $"{ts.TotalDays:0.#} day(s)";
        if (ts.TotalHours >= 1) return $"{ts.TotalHours:0.#}h";
        return $"{ts.TotalMinutes:0.#}m";
    }

    // Distinct states must read clearly — a legitimate "Processed · 0 ideas" is NOT a failure.
    private static string VideoStateLabel(VideoJobStatus status) => status switch
    {
        VideoJobStatus.Pending => "Pending",
        VideoJobStatus.InProgress => "In progress",
        VideoJobStatus.Done => "Done",
        VideoJobStatus.Failed => "Failed",
        VideoJobStatus.NoTranscript => "No transcript",
        VideoJobStatus.ProcessedNoIdeas => "Processed · 0 ideas",
        _ => status.ToString(),
    };

    private static string ConceptStateLabel(ConceptJobStatus status) => status switch
    {
        ConceptJobStatus.Pending => "Pending",
        ConceptJobStatus.InProgress => "In progress",
        ConceptJobStatus.Done => "Done",
        ConceptJobStatus.Failed => "Failed",
        _ => status.ToString(),
    };
}
