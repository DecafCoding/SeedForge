@page "/config"
@rendermode InteractiveServer
@using SeedForge.Domain
@using SeedForge.Features.Config
@using SeedForge.Services.Ai
@inject ProfileService Profiles
@inject FailoverSettingsService Failover
@inject ConnectionTester ConnectionTester

<PageTitle>Config Profiles</PageTitle>

<h1>Config Profiles</h1>
<p>Manage named model-configuration profiles, switch the active one, and test connectivity per slot. Exactly one profile is active. API keys left blank resolve from user-secrets — they are never displayed or stored here.</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_profiles is null)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="card-title fs-5">Failover</h2>
            <p class="text-muted small mb-2">
                When a model endpoint is unreachable — connection refused, timeout, or HTTP 5xx — retry that one call
                once against another profile's matching slot. Off by default; e.g. fall back to <em>All OpenAI</em> when
                the local rig is down.
            </p>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="failoverEnabled"
                           @bind="_failoverEnabled" disabled="@_busy" />
                    <label class="form-check-label" for="failoverEnabled">Enable failover</label>
                </div>
                <label class="form-label mb-0">Fallback profile:</label>
                <select class="form-select w-auto" @bind="_fallbackProfileId" disabled="@(_busy || !_failoverEnabled)">
                    <option value="">(choose…)</option>
                    @foreach (var p in _profiles)
                    {
                        <option value="@p.Id">@p.Name @(p.IsActive ? "(active)" : "")</option>
                    }
                </select>
                <button class="btn btn-primary btn-sm" disabled="@_busy" @onclick="SaveFailoverAsync">
                    @(_busy && _action == "failover" ? "Saving…" : "Save")
                </button>
            </div>
            @if (_failoverEnabled && string.IsNullOrEmpty(_fallbackProfileId))
            {
                <div class="text-warning small mt-1">Choose a fallback profile to enable failover.</div>
            }
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Profile</th>
                <th>Active</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var profile in _profiles)
            {
                <tr>
                    <td>@profile.Name</td>
                    <td>@(profile.IsActive ? "✓ active" : "")</td>
                    <td>
                        @if (!profile.IsActive)
                        {
                            <button class="btn btn-primary btn-sm me-1" disabled="@_busy"
                                    @onclick="() => SetActiveAsync(profile.Id)">
                                @(_busy && _activating == profile.Id ? "Switching…" : "Make Active")
                            </button>
                        }
                        <button class="btn btn-outline-secondary btn-sm" disabled="@_busy"
                                @onclick="() => BeginEdit(profile)">Edit</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-success btn-sm mb-3" disabled="@_busy" @onclick="BeginNew">+ New Profile</button>

    @if (_editing is not null)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="card-title">@(_editing.Id == 0 ? "New profile" : $"Edit “{_editing.Name}”")</h2>
                <div class="mb-3" style="max-width:30rem">
                    <label class="form-label">Profile name</label>
                    <input class="form-control" @bind="_editing.Name" disabled="@_busy" />
                </div>

                @foreach (var slot in Enum.GetValues<ModelSlot>())
                {
                    var opts = _editSlots[slot.ToString()];
                    <fieldset class="border rounded p-2 mb-2">
                        <legend class="fs-6">@slot</legend>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label small">Base URL</label>
                                <input class="form-control form-control-sm" @bind="opts.BaseUrl" disabled="@_busy" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Model</label>
                                <input class="form-control form-control-sm" @bind="opts.Model" disabled="@_busy" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Timeout (s)</label>
                                <input class="form-control form-control-sm" type="number" @bind="opts.TimeoutSeconds" disabled="@_busy" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">API key</label>
                                <input class="form-control form-control-sm" type="password" placeholder="from secrets" @bind="opts.ApiKey" disabled="@_busy" />
                            </div>
                        </div>
                    </fieldset>
                }

                <button class="btn btn-primary btn-sm me-1" disabled="@(_busy || string.IsNullOrWhiteSpace(_editing.Name))" @onclick="SaveEdit">
                    @(_busy && _action == "save" ? "Saving…" : "Save Profile")
                </button>
                <button class="btn btn-secondary btn-sm" disabled="@_busy" @onclick="() => _editing = null">Cancel</button>
            </div>
        </div>
    }

    <h2>Test connections</h2>
    <p>Each slot resolves against the currently active profile.</p>
    <table class="table">
        <thead>
            <tr>
                <th>Slot</th>
                <th>Action</th>
                <th>Result</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var slot in Enum.GetValues<ModelSlot>())
            {
                <tr>
                    <td>@slot</td>
                    <td>
                        <button class="btn btn-outline-secondary btn-sm" disabled="@_busy"
                                @onclick="() => TestAsync(slot)">
                            @(_busy && _testing == slot ? "Testing…" : "Test")
                        </button>
                    </td>
                    <td>
                        @if (_results.TryGetValue(slot, out var result))
                        {
                            @if (result.Ok)
                            {
                                <span class="text-success">OK (@result.LatencyMs ms)</span>
                            }
                            else
                            {
                                <span class="text-danger">Error: @result.Error</span>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ConfigProfile>? _profiles;
    private readonly Dictionary<ModelSlot, ConnectionResult> _results = new();
    private bool _busy;
    private int? _activating;
    private ModelSlot? _testing;
    private string? _action;
    private string? _error;

    private ConfigProfile? _editing;
    private Dictionary<string, LlmOptions> _editSlots = new();

    // Failover: master on/off + the fallback profile (bound as string from the <select>).
    private bool _failoverEnabled;
    private string? _fallbackProfileId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _profiles = await Profiles.ListAsync();
        var failover = await Failover.GetAsync();
        _failoverEnabled = failover.Enabled;
        _fallbackProfileId = failover.FallbackProfileId?.ToString();
    }

    private async Task SaveFailoverAsync()
    {
        _busy = true;
        _action = "failover";
        _error = null;
        try
        {
            int? fallbackId = int.TryParse(_fallbackProfileId, out var id) ? id : null;
            if (_failoverEnabled && fallbackId is null)
            {
                _error = "Choose a fallback profile to enable failover.";
                return;
            }
            await Failover.UpdateAsync(_failoverEnabled, fallbackId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            _action = null;
        }
    }

    private async Task SetActiveAsync(int id)
    {
        _busy = true;
        _activating = id;
        _error = null;
        try
        {
            await Profiles.SetActiveAsync(id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            _activating = null;
        }
    }

    private void BeginNew()
    {
        _editing = new ConfigProfile { Name = "" };
        _editSlots = BlankSlots();
    }

    private void BeginEdit(ConfigProfile profile)
    {
        // Edit a fresh copy so a cancel leaves the list untouched.
        _editing = new ConfigProfile
        {
            Id = profile.Id,
            Name = profile.Name,
            IsActive = profile.IsActive,
            CreatedAtUtc = profile.CreatedAtUtc,
            SlotsJson = profile.SlotsJson,
        };

        var stored = ProfileSlots.Deserialize(profile.SlotsJson);
        _editSlots = BlankSlots();
        foreach (var slot in Enum.GetValues<ModelSlot>())
        {
            if (stored.TryGetValue(slot.ToString(), out var o))
            {
                _editSlots[slot.ToString()] = new LlmOptions
                {
                    BaseUrl = o.BaseUrl,
                    Model = o.Model,
                    TimeoutSeconds = o.TimeoutSeconds,
                    // Never surface a stored key; leave blank so it resolves from user-secrets unless re-entered.
                    ApiKey = string.Empty,
                };
            }
        }
    }

    private static Dictionary<string, LlmOptions> BlankSlots()
    {
        var d = new Dictionary<string, LlmOptions>();
        foreach (var slot in Enum.GetValues<ModelSlot>())
            d[slot.ToString()] = new LlmOptions { TimeoutSeconds = 300 };
        return d;
    }

    private async Task SaveEdit()
    {
        if (_editing is null) return;
        _busy = true;
        _action = "save";
        _error = null;
        try
        {
            _editing.SlotsJson = ProfileSlots.Serialize(_editSlots);
            await Profiles.SaveAsync(_editing);
            _editing = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            _action = null;
        }
    }

    private async Task TestAsync(ModelSlot slot)
    {
        _busy = true;
        _testing = slot;
        try
        {
            _results[slot] = await ConnectionTester.TestConnectionAsync(slot);
        }
        finally
        {
            _busy = false;
            _testing = null;
        }
    }
}
