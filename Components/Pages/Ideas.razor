@page "/ideas"
@rendermode InteractiveServer
@using SeedForge.Features.Browse
@inject BrowseQueries Browse

<PageTitle>Ideas</PageTitle>

<h1>Ideas</h1>
<p>Every extracted idea, with its source video, latest score, pass/fail, and creation date. Click a row to open its full version history in the Concept Browser. Score columns are abbreviated: N = Novelty (freshness of the idea), C = Coherence (internal logical consistency), P = Potential (richness as science fiction), S = Suitability (suitability for a developed story), and M = Mean (the average of the four, shown green when the idea passes and red when it doesn't).</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_busy)
{
    <p><em>Loading…</em></p>
}
else if (_rows.Count == 0)
{
    <p><em>No ideas yet — run the pipeline first.</em></p>
}
else
{
    <p class="text-muted">@_rows.Count idea@(_rows.Count == 1 ? "" : "s").</p>
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>Idea</th>
                <th>Parent Video</th>
                <th class="text-end">N</th>
                <th class="text-end">C</th>
                <th class="text-end">P</th>
                <th class="text-end">S</th>
                <th class="text-end">M</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _rows)
            {
                <tr style="cursor:pointer" @onclick="() => OpenConcepts(r.Id)">
                    <td title="@r.Premise">@Truncate(r.Premise, 160)</td>
                    <td @onclick:stopPropagation="true">
                        @if (r.VideoId is int videoId)
                        {
                            <a href="@($"/videos/{videoId}")">@(string.IsNullOrWhiteSpace(r.VideoTitle) ? r.VideoUrl : r.VideoTitle)</a>
                        }
                        else
                        {
                            <em class="text-muted">(pasted transcript)</em>
                        }
                    </td>
                    <td class="text-end" title="@Dec(r.Novelty)">@Whole(r.Novelty)</td>
                    <td class="text-end" title="@Dec(r.Coherence)">@Whole(r.Coherence)</td>
                    <td class="text-end" title="@Dec(r.Potential)">@Whole(r.Potential)</td>
                    <td class="text-end" title="@Dec(r.Suitability)">@Whole(r.Suitability)</td>
                    <td class="text-end" title="@Dec(r.Mean)">
                        <span class="badge @MeanBadgeClass(r.Passed)">@Whole(r.Mean)</span>
                    </td>
                    <td><small class="text-muted">@r.CreatedAtUtc.ToString("MM/dd/yyyy")</small></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<IdeaRow> _rows = Array.Empty<IdeaRow>();
    private bool _busy = true;
    private string? _error;

    [Inject] private NavigationManager Nav { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _rows = await Browse.IdeaRowsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load ideas: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private void OpenConcepts(int ideaId) => Nav.NavigateTo($"/concepts?ideaId={ideaId}");

    // Scores are stored 0–1; show a whole number on a 0–10 scale (truncated), with the 1-decimal value on hover.
    // The +1e-9 nudge counters binary-float underestimation (e.g. 0.3 → 2.999… → 3, not 2).
    private static string Whole(double? value) => value is null ? "—" : ((int)(value.Value * 10 + 1e-9)).ToString();
    private static string? Dec(double? value) => value is null ? null : (value.Value * 10).ToString("0.0");

    // Square badge colored by pass/fail: green for pass, red for fail, grey while unscored.
    private static string MeanBadgeClass(bool? passed) => passed switch
    {
        true => "bg-success",
        false => "bg-danger",
        null => "bg-secondary",
    };

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "…";
}
